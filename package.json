{
  "name": "canvas-cli",
  "version": "1.0.0",
  "description": "CLI tool for Canvas LMS - view courses, assignments, grades, and more from your terminal",
  "type": "module",
  "bin": {
    "canvas": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "canvas",
    "lms",
    "cli",
    "education",
    "university"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "mammoth": "^1.12.0",
    "ora": "^8.0.0",
    "pdf-parse": "^2.4.5",
    "puppeteer-core": "^24.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
